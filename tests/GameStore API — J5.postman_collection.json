    {
      "name": "05 — Featured (NGS-108)",
      "item": [
        {
          "name": "Featured — réponse de base",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// TODO 1 — Status 200",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "",
                  "",
                  "// TODO 2 — Réponse contient 'count' et 'featured'",
                  "pm.test(\"Chaque jeu a les champs : count, featured\", function () {",
                  "    const body = pm.response.json();",
                  "    [\"count\", \"featured\"].forEach(key => {",
                  "        pm.expect(body[0]).to.have.property(key)",
                  "        })    ",
                  "}) ",
                  "",
                  "// TODO 3 — 'featured' est un tableau de max 5 éléments",
                  "pm.test(\"Le tableau 'featured' contient au maximum 5 éléments\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.featured).to.be.an(\"array\");",
                  "    pm.expect(body.featured.length).to.be.at.most(5);",
                  "});",
                  "",
                  "// TODO 4 — Les jeux sont triés par rating décroissant",
                  "pm.test(\"Les jeux sont triés par rating décroissant\", function () {",
                  "    const body = pm.response.json();",
                  "    const ratings = body.featured.map(game => game.rating);",
                  "    const sortedRatings = [ratings].sort((a, b) => b - a);",
                  "",
                  "    pm.expect(ratings).to.deep.equal(sortedRatings);",
                  "});",
                  "",
                  "// il n'y a pas d endpoint"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
